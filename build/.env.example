COMPOSE_PROJECT_NAME=rag
AGENT_VERSION=0.1.1
DOCLING_VERSION=0.1.0


#----- Weaviate Configs -----#
WEAVIATE_VERSION=1.31.2
WEAVIATE_HOST=weaviate
WEAVIATE_HTTP_PORT=8081 # Host Port
WEAVIATE_GRPC_PORT=50051

#----- Phoenix Configs -----#
PHOENIX_VERSION=version-10.15.0
PHOENIX_COLLECTOR_ENDPOINT=http://rag-phoenix-1:6006/v1/traces
PHOENIX_PROJECT_NAME=RAG-agent

#----- Agent Model Configs -----#
MODEL_ENDPOINT=
MODEL_NAME=
MODEL_API_KEY=

MCP_SERVER_VERSION=0.1.0
MCP_SERVER_URL=http://rag-mcp-server-1:8000

#----- Weaviate Embedding Model -----#
EMBEDDING_MODEL=all-mpnet-base-v2

#----- Object Storage Configs (S3-compatible — SeaweedFS, MinIO, etc.) -----#
OBJECT_STORE_ENDPOINT=seaweedfs:8333
OBJECT_STORE_ACCESS_KEY=seaweedfsadmin
OBJECT_STORE_SECRET_KEY=seaweedfspassword
OBJECT_STORE_SECURE=false
OBJECT_STORE_BUCKET=media
# OBJECT_STORE_EXTERNAL_ENDPOINT=localhost:8333  # External endpoint for pre-signed URLs
# OBJECT_STORE_PRESIGN_EXPIRY=3600               # Pre-signed URL expiry in seconds
          # Pre-signed URL expiry in seconds

SEAWEEDFS_S3_PORT=8333

# A2A Agent Configuration
# Use host.minikube.internal so the agent card URL is reachable from Minikube pods
A2A_AGENT_URL=http://host.minikube.internal:10010

# Server Configuration
SERVER_PORT=3001

# Supported file extensions
IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.gif,.webp,.bmp,.tiff
VIDEO_EXTENSIONS=.mp4,.mov,.avi,.mkv,.webm,.flv
DOCUMENT_EXTENSIONS=.pdf,.txt,.md

USE_CUDA=true

IMAGE_MODE=base64

COMPOSE_PROJECT_NAME=research
AGENT_VERSION=0.1.0


#----- Weaviate Configs -----#
WEAVIATE_VERSION=1.31.2
WEAVIATE_HOST=weaviate
WEAVIATE_HTTP_PORT=8081 # Host Port
WEAVIATE_GRPC_PORT=50051

#----- Postgres Configs -----#
POSTGRES_VERSION=15
POSTGRES_USER=user
POSTGRES_PASSWORD=somepassword
POSTGRES_DB=postgres
POSTGRES_PORT=5432

PGADMIN_VERSION=latest
PGADMIN_DEFAULT_EMAIL=user@email.com
PGADMIN_DEFAULT_PASSWORD=somepassword
PGADMIN_PORT=5050

#----- Phoenix Configs -----#
PHOENIX_VERSION=version-10.15.0
PHOENIX_ENDPOINT=http://research-phoenix-1:6006/v1/traces


#----- Agent Model Configs -----#
MODEL_ENDPOINT=
MODEL_NAME=
MODEL_API_KEY=

MCP_SERVER_VERSION=0.1.0

model_source=

#----- VLM Target Detection/Classification Configs -----#
# These are used by the VLM-based target detection and classification tools.
# They fall back to TOOL_LLM_URL/TOOL_LLM_NAME/API_KEY if not set.
VLM_ENDPOINT=
VLM_MODEL=
VLM_API_KEY=

#----- YOLO/Classifier Configs -----#
# USE_YOLO=true            # Set to false to use stub detections
# YOLO_MODEL=yolov8n.pt    # Path or name of YOLOv8 model weights
# USE_CLASSIFIER=true      # Set to false to use stub classifications
# CLASSIFIER_WEIGHTS=      # Path to custom classifier weights

#----- MinIO Object Storage Configs -----#
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=data
MINIO_CONSOLE_PORT=9001
MINIO_API_PORT=9000
# MINIO_EXTERNAL_ENDPOINT=localhost:9000  # External endpoint for pre-signed URLs (if different from MINIO_ENDPOINT)
# MINIO_PRESIGN_EXPIRY=3600              # Pre-signed URL expiry in seconds

#----- Multimodal A2A Agent Configs -----#
# MAX_VIDEO_FRAMES=8                     # Number of frames to sample from videos
# MCP_SERVER_URL=http://research-mcp-server-1:8000

IMAGE_MODE=base64
